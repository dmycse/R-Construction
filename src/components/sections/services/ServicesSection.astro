---
import { getEntry } from 'astro:content';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import SectionFooter from "@/components/ui/SectionFooter.astro";
import ServiceButton from "@/components/sections/services/ServiceButton.astro";
import ServiceDetails from "@/components/sections/services/ServiceDetails.astro";

const servicesEntry = await getEntry('services', 'services_data');

if (!servicesEntry) {
  throw new Error("Services data not found");
}

const {
  sectionId, 
  sectionTitle, 
  sectionSubtitle, 
  sectionText, 
  ctaText,
  ctaBtn, 
  servicesData
} = servicesEntry.data;
---

<section
  id={sectionId} 
  class="section-padding bg-slate-50 scroll-mt-10"
>  
  <div class="page-container">
    <div class="flex flex-col gap-10 lg:gap-16 xl:gap-24">
      <SectionHeader
        sectionId={sectionId} 
        sectionTitle={sectionTitle} 
        sectionSubtitle={sectionSubtitle} 
        sectionText={sectionText}
      />
      <main 
        data-mode="mobile"
        class="lg:hidden fade-in-right" 
      >
        {servicesData.map(service => (
          <div
            data-id={service.id}
            data-active="false"
            class="group/item flex flex-col gap-4"
          >
            <ServiceButton name={service.name} icon={service.icon} />
            <ServiceDetails {...service} />
          </div>
        ))}
      </main>
      <main
        data-mode="desktop" 
        class="hidden fade-in-left lg:grid grid-cols-[40%_1fr] xl:grid-cols-[30%_1fr] items-stretch gap-10"
      >
        <div class="flex flex-col justify-between">
          {servicesData.map((service, index) => (
            <div 
              data-id={service.id} 
              data-active={index === 0 ? "true" : "false"} 
              class="group/item"
            >
              <ServiceButton name={service.name} icon={service.icon} />
            </div>
          ))}
        </div>
        <div class="fade-in-right lg:p-8 xl:p-12 grid grid-cols-1 grid-rows-1 bg-white shadow-md">
          {servicesData.map((service, index) => (
            <div 
              data-content-id={service.id}
              data-active={index === 0 ? "true" : "false"}
              class="col-start-1 row-start-1 opacity-0 data-[active=true]:opacity-100 
                    transition-opacity duration-500 pointer-events-none">
              <ServiceDetails {...service} />
            </div>
          ))}
        </div>
      </main>
      {(ctaText.visible || ctaBtn.visible) && (
        <SectionFooter
          sectionId={sectionId}
          ctaText={ctaText}
          ctaBtn={ctaBtn}
        />
      )}
    </div>
  </div>
</section>

<script>
  import { initServicesContent } from '@/scripts/servicesDisplay';
  initServicesContent();
</script>