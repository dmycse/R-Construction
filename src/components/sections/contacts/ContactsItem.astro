---
import IconComponent from "@/components/ui/IconComponent.astro";
import type { ContactsDataSchema } from "@/content/config";
import { Icon } from "astro-icon/components";

interface Props {
  contactData: ContactsDataSchema['contactsData'][number];
}

const { title, subtitleText, contactInfo } = Astro.props.contactData
---

<div class="flex gap-8">
  <div class="">
    <span class="inline-flex items-center justify-center">
      <IconComponent 
        name={contactInfo.icon}
        className="size-8 text-amber-400"
      />
    </span>
  </div>
  <div class="grid grid-cols-1 grid-rows-3">
    <h3 class="text-xl md:text-2xl 2xl:text-3xl font-primary font-bold tracking-wider">
      {title}
    </h3>
    <p class="text-lg md:text-xl 2xl:text-2xl">
      {subtitleText}
    </p>
    <a 
      href={contactInfo.href}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xl md:text-lg 2xl:text-2xl font-semibold tracking-wide"
    >
      {contactInfo.label}
    </a>
  </div>
</div>
