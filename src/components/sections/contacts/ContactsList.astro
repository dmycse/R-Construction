---
import type { ContactsDataSchema } from "@/content/config";
import ContactsItem from "@/components/sections/contacts/ContactsItem.astro";

interface Props {
  contacts: ContactsDataSchema['contactsData'];
}

const { contacts } = Astro.props
---

<div 
  class="xl:pt-25 grid grid-cols-1 sm:grid-cols-[auto_1fr] lg:grid-cols-2
        gap-8 sm:gap-10 md:gap-12 xl:gap-16"
  >
  {contacts.map(contactData => <ContactsItem contactData={contactData} />)}
</div>
