---
import { Image } from "astro:assets";
import { getEntry } from 'astro:content';
import LinkButton from '@/components/ui/LinkButton.astro';

const heroEntry = await getEntry('hero', 'hero_data');

if (!heroEntry) {
  throw new Error("Hero data not found");
}

const {sectionId, sectionImage, sectionTitle, sectionSubtitle, sectionText, ctaBtn} = heroEntry.data;
---

<section id={sectionId} class="w-full h-[85svh] 2xl:h-[95svh] landscape:max-lg:h-svh flex items-center justify-center relative z-10 scroll-mt-40">
  <div class="absolute inset-0 z-10 bg-linear-to-l from-black/80 to-black/20" />
  <Image 
    src={sectionImage} 
    alt="hero" 
    class="size-full absolute inset-0 z-0 object-cover object-center"
  />
  <div class="page-container pb-4 h-full md:w-4/5 xl:w-3/5 2xl:w-1/2 landscape:max-md:w-4/5 sm:text-center flex flex-col sm:items-center justify-center gap-y-10 md:gap-y-16 2xl:gap-y-24 landscape:max-md:gap-y-4 landscape:md:gap-y-10 landscape:2xl:gap-y-26 relative z-20">
    <h1 class="flex flex-col gap-y-10 landscape:max-md:gap-y-8 text-slate-200">
      <span>{sectionTitle}</span>
      <span class="text-2xl md:text-3xl lg:text-5xl 2xl:text-7xl text-accent font-secondary font-bold md:leading-[1.3]">{sectionSubtitle}</span>
    </h1>
    <p class="text-slate-200 text-xl md:text-2xl 2xl:text-4xl">{sectionText}</p>
    {ctaBtn.visible && (
      <LinkButton
        link={ctaBtn} 
        linkStyle="px-4 md:px-6 lg:px-8 py-2 md:py-4 w-2/3 sm:max-w-1/2 lg:max-w-2/5 bg-accent"
        labelStyle="text-xl lg:text-2xl 2xl:text-3xl" 
      />
    )}
  </div>
</section>