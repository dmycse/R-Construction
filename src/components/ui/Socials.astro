---
import type { ContactsType } from "@/content/config";
import IconComponent from "@/components/ui/IconComponent.astro";

interface Props {
  socialLinks: ContactsType
};

const { socialLinks} = Astro.props;
---

<div class="hidden md:flex items-center gap-4">
  {socialLinks.map(elem => {
    if (!elem.visible) return null;
    
    return (
      <a 
        href={elem.url}
        target="_blank" 
        rel="noopener noreferrer" 
        aria-label={elem.name}
        title={elem.name} 
        class="flex items-center"
      >
        <IconComponent name={elem.icon} className="p-1 w-7 h-7 bg-primary text-tertiary rounded-md" />
        <span class="font-medium">
          {elem.text}
        </span>
      </a>
    );
  })}
</div>