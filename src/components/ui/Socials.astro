---
import type { ContactsType } from "@/content/config";
import { iconsMap } from "@/utils/iconsMap";

interface Props {
  socials: ContactsType
};

const { socials } = Astro.props;
---

<div class="hidden md:flex items-center gap-2">
  {socials.map(elem => {
    if (!elem.visible) return null;

    const iconFileName = elem.icon.split('/').pop() ?? '';
    const IconComponent = iconsMap[iconFileName];
    
    return (
      <a 
        href={elem.url}
        target="_blank" 
        rel="noopener noreferrer" 
        aria-label={elem.name}
        title={elem.name} 
        class="flex items-center gap-2"
      >
        {IconComponent && <IconComponent class="p-1 w-8 h-8 text-primary" />}
        <span class="font-medium text-primary">
          {elem.text}
        </span>
      </a>
    );
  })}
</div>