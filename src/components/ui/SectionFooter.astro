---
import type { CtaDataSchema } from '@/content/config';
import LinkButton from '@/components/ui/LinkButton.astro';

interface Props extends CtaDataSchema {
  sectionId: string
}
  
const { sectionId,ctaText, ctaBtn } = Astro.props;

const stylesConfig = {
  home: {
    footerStyle: 'w-full flex flex-col items-center justify-center gap-y-4 md:gap-y-6 2xl:gap-y-8',
    textStyle: '',
    linkStyle: 'w-4/5 sm:max-w-1/2 lg:max-w-2/5'
  },
  services: {
    footerStyle: 'fade-in-left flex flex-col gap-8 lg:gap-12 xl:gap-16',
    textStyle: 'lg:text-center',
    linkStyle: 'lg:mx-auto w-4/5 sm:max-w-1/2 lg:max-w-1/3 xl:max-w-1/4 2xl:max-w-1/5'
  },
  projects: {
    footerStyle: 'page-container flex lg:justify-center',
    textStyle: 'lg:text-center',
    linkStyle: ''
  },
  reviews: {
    footerStyle: 'self-start lg:mt-10 lg:max-w-3/5 xl:max-w-full 2xl:max-w-2/3 flex flex-col gap-8 lg:gap-10 xl:gap-12',
    textStyle: '',
    linkStyle: 'w-full max-w-4/5 sm:max-w-1/2 lg:max-w-3/5 xl:max-w-1/2 2xl:max-w-3/5'
  }
}[sectionId];
---

<footer class={`${stylesConfig?.footerStyle}`}>
  {ctaText.visible && (
    <p class={`font-primary text-xl 2xl:text-3xl text-slate-500 ${stylesConfig?.textStyle}`}>
      {ctaText.text}
    </p>
  )}
  {ctaBtn.visible && (
    <LinkButton
      link={ctaBtn} 
      linkStyle={`bg-accent ${stylesConfig?.linkStyle}`}
    />
  )}
</footer>