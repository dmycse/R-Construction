---
import GetAQuoteBtn from '../ui/GetAQuoteBtn.astro';

interface Props {
  links: {
    visible: boolean;
    name: string;
    path: string;
  }[];
  button: {
    visible: boolean;
    name: string;
    path: string;
    icon: string;
  };
  className?: string
}

const { links, button, className } = Astro.props;
---

<nav class={`${className} flex items-center gap-4 md:gap-8`}>
  <ul class="flex gap-0 text-white text-sm font-light font-primary uppercase tracking-wide">
    {links.map(link => link.visible && (
      <li class="first:text-amber-400 after:content-['/'] after:mx-4 last:after:content-none">
        <a href={`#${link.path}`}>{link.name}</a>
      </li>
    ))}
  </ul>
  {button.visible && <GetAQuoteBtn button={button} />}
</nav>  