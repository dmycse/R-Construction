---
import type { HeaderDataSchema } from "@/content/config";

interface Props {
  links: HeaderDataSchema['links'];
  ulStyle?: string;
  liStyle?: string;
}

const { links, ulStyle = "", liStyle = "" } = Astro.props;
---

<ul data-nav-links class={ulStyle}>
  {links.map(link => link.visible && (
    <li class={liStyle}>
      <a 
        href={`#${link.path}`} 
        data-path={link.path}
        data-menu-close 
        class="text-white text-xl font-normal uppercase tracking-wider hover:text-tertiary
               data-[active=true]:text-accent data-[active=true]:font-semibold
               transition-colors duration-300 ease-in-out"
      >
        {link.name}
      </a>
    </li>
  ))}
</ul>

<script>
  import { initNavLinks } from '@/scripts/initNavLinks'; 
  initNavLinks('[data-nav-links]');
</script>