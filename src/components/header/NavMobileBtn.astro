---
import type { HeaderDataSchema } from "@/content/config";
import IconComponent from '@/components/ui/IconComponent.astro';

interface Props {
  icons: HeaderDataSchema['mobileIcons']
};

const { icons } = Astro.props;
---

<button
  aria-label="Toggle menu"
  aria-controls="mobile-menu"
  aria-expanded="false"
  class="relative z-50 flex items-center justify-center"
>
  <span 
    aria-hidden="true"
    class="absolute right-1
          opacity-100 rotate-0 scale-100
          group-data-[menu-open=true]/menu:opacity-0 
          group-data-[menu-open=true]/menu:rotate-90 
          group-data-[menu-open=true]/menu:scale-50
          transition-all duration-500 ease-in-out"
  >
    <IconComponent
      name={icons.open}
      className="size-9 text-tertiary cursor-pointer"
    />
  </span>
  <span 
    aria-hidden="true"
    class="absolute right-1
          opacity-0 -rotate-90 scale-50
          group-data-[menu-open=true]/menu:opacity-100 
          group-data-[menu-open=true]/menu:rotate-0 
          group-data-[menu-open=true]/menu:scale-100
          transition-all duration-500 ease-in-out"
  >
    <IconComponent
      name={icons.close}
      className="size-9 text-tertiary cursor-pointer"
    />
  </span>
</button>